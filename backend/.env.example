# Postgres connection for local dev
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tornare

# JWT signing secret (change in production)
JWT_SECRET=replace-with-a-strong-random-secret

# Comma-separated allowed frontend origins for CORS (use * only for local/dev)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Battle.net OAuth2 credentials (replace with your own for local testing)
BATTLENET_CLIENT_ID=your_bnet_client_id
BATTLENET_CLIENT_SECRET=your_bnet_client_secret
BATTLENET_REDIRECT_URI=http://localhost:8000/api/auth/battlenet/callback
FRONTEND_URL=http://localhost:5173

# Discord OAuth2 credentials
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://localhost:8000/api/auth/discord/callback

# Discord bot credentials (for slash command webhook verification and channel permission checks)
# DISCORD_BOT_PUBLIC_KEY=your_discord_bot_public_key
# DISCORD_BOT_TOKEN=your_discord_bot_token

# Optional: application log verbosity
# Examples:
#   RUST_LOG=info
#   RUST_LOG=debug
#   RUST_LOG=debug,tower_http=info,axum=info,sqlx=warn
RUST_LOG=debug

# Email configuration
# EMAIL_DRIVER=smtp  → local Mailpit (default; web UI at http://localhost:8025)
# EMAIL_DRIVER=resend → Resend REST API (production)
# Keep EMAIL_DRIVER=resend available for later by setting RESEND_API_KEY.
EMAIL_DRIVER=smtp
FROM_EMAIL=noreply@tornare.gg
SMTP_HOST=mailpit
SMTP_PORT=1025
# SMTP auth/TLS (optional; useful for Gmail and other authenticated SMTP relays)
# Gmail example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_TLS_MODE=starttls
# SMTP_USERNAME=your_gmail@gmail.com
# SMTP_PASSWORD=your_16_char_app_password
# Safety note: in non-production, when SMTP_HOST=smtp.gmail.com, all outgoing
# emails are redirected to antoinejeanmec@hotmail.fr to prevent accidental leaks.
SMTP_TLS_MODE=none
# SMTP_USERNAME=
# SMTP_PASSWORD=
# RESEND_API_KEY=re_xxxxxxxxxxxx
